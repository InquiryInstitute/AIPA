{
  "name": "aipa-slides",
  "version": "1.0.0",
  "description": "Slidev slides for AIPA lectures",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-slides.js",
    "build": "npm run generate && node scripts/build-all.js",
    "export-pdf": "node scripts/export-pdf.js",
    "build-6up": "node scripts/pdf-6up.js",
    "build:instructor": "npm run build && npm run export-pdf && npm run build-6up",
    "dev": "npx slidev slides/ch01/lecture-01.md --open"
  },
  "devDependencies": {
    "@slidev/cli": "^52.0.0",
    "@slidev/theme-default": "^0.25.0"
  }
}
